# Neo's Claw 環境変数設定例 : このファイルを .env にコピーして値を埋めてください

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_k_m

# Web UI
WEB_ENABLED=true
PORT=58080

# Slack
# 設定手順 : `docs/slack-setup.md` を参照
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-

# Discord
# 設定手順 : `docs/discord-setup.md` を参照
DISCORD_ENABLED=false
DISCORD_TOKEN=

# その他
# デバッグログを有効にする (`true`・`false`)
DEBUG=false

# MCP 設定ファイルのパス (デフォルト : `./mcp-config.json`)
#MCP_CONFIG=./mcp-config.json
# ワークスペースのパス (デフォルト : `./workspace/`)
#MCP_WORKSPACE=/PATH/TO/workspace

# セッション永続化
# 会話履歴を保存するディレクトリ (デフォルト : ./sessions)
#SESSION_PERSIST_DIR=./sessions
